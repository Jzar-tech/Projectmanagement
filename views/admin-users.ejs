<%- include('partials-header', { title: 'Users' }) %>
<h1>User Management</h1><p>Admin creates teammate accounts here. Active teammates share the same projects, tasks, and notes.</p><% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
<section class="card form-card"><h2>Create teammate</h2><form method="post" action="/admin/users"><div class="form-row"><input name="name" placeholder="Name" required><input type="email" name="email" placeholder="Email" required></div><div class="form-row"><input type="password" name="password" minlength="8" placeholder="Temporary password" required><select name="role"><option value="member">Member</option><option value="admin">Admin</option></select></div><button>Create user</button></form></section>
<section class="card"><h2>Team accounts</h2><div class="user-list"><% users.forEach(account => { %><div class="user-row"><div><strong><%= account.name %></strong><span><%= account.email %></span><small><%= account.disabled ? 'Disabled' : 'Active' %></small></div><form method="post" action="/admin/users/<%= account.id %>/role"><select name="role"><option value="member" <%= account.role === 'member' ? 'selected' : '' %>>Member</option><option value="admin" <%= account.role === 'admin' ? 'selected' : '' %>>Admin</option></select><button class="small">Save role</button></form><form method="post" action="/admin/users/<%= account.id %>/toggle"><button class="<%= account.disabled ? '' : 'danger' %> small"><%= account.disabled ? 'Enable' : 'Disable' %></button></form></div><% }) %></div></section>
<%- include('partials-footer') %>
