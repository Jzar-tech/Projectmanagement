<%- include('partials-header', { title: 'Register' }) %>
<section class="auth card"><h1>Create Workspace Account</h1><% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %><form method="post" action="/register"><label>Name<input name="name" required></label><label>Email<input type="email" name="email" required></label><label>Password<input type="password" name="password" minlength="8" required></label><label>Private invite code<input type="password" name="inviteCode" required></label><button>Create account</button></form><p class="muted">Normal signup is disabled unless self-registration is explicitly enabled. Ask the admin to create your account.</p><p><a href="/login">Back to login</a></p></section>
<%- include('partials-footer') %>
